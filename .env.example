# Aria — Local Development Reference
# These values are entered by the user in the Settings screen.
# They are stored on-device only (AsyncStorage / localStorage).
# Do NOT commit real keys to this file or any file in the repo.

GEMINI_API_KEY=your_gemini_api_key_here
CLOCKIFY_API_KEY=your_clockify_api_key_here
WORK_GITHUB_TOKEN=ghp_your_work_token_here
WORK_GITHUB_OWNER=your_github_username
WORK_GITHUB_REPO=your_work_repo_name
PERSONAL_GITHUB_TOKEN=ghp_your_personal_token_here
PERSONAL_GITHUB_OWNER=your_github_username
PERSONAL_GITHUB_REPO=your_personal_repo_name
